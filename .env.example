# =============================================================================
# Harness Memory Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# Run: cp .env.example .env
# =============================================================================

# --- Project Root -----------------------------------------------------------
# Absolute path to this repository
HARNESS_PROJECT_DIR=/path/to/my-local-harness

# --- Obsidian Vault ---------------------------------------------------------
# Your Obsidian vault root directory
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# Subfolders to index (comma-separated, no spaces)
INGEST_DIRS=Projects,Knowledge

# --- ChromaDB ---------------------------------------------------------------
# Path to ChromaDB persistent storage (relative paths resolve from PROJECT_DIR)
CHROMA_DB_DIR=./chroma_db

# Collection name in ChromaDB
COLLECTION_NAME=obsidian_notes

# Embedding model (must be available in Ollama)
EMBED_MODEL=nomic-embed-text

# Chunking configuration for ingest
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# --- Claude Session Sync ----------------------------------------------------
# Directory where Claude Code stores session logs
CLAUDE_PROJECTS_DIR=/path/to/.claude/projects

# Archive directory for classified-trash sessions
CLAUDE_ARCHIVE_DIR=/path/to/.claude/archive

# Output directory for daily session notes (inside Obsidian vault)
OBSIDIAN_LOGS_DIR=/path/to/vault/Logs

# Output directory for RESEARCH session notes (inside Obsidian vault)
OBSIDIAN_KNOWLEDGE_DIR=/path/to/vault/Knowledge

# Existing vault folders to scan when adding related-note wikilinks
RELATED_NOTE_DIRS=Projects,Knowledge
RELATED_NOTE_LIMIT=5
RELATED_NOTE_MIN_SCORE=8

# Number of days to look back for unprocessed sessions
LOOKBACK_DAYS=7

# LLM model for classification and summarization (must be available in Ollama)
CLASSIFY_MODEL=llama3:8b

# --- Virtual Environment ----------------------------------------------------
# Path to the Python virtual environment (used in .mcp.json)
VENV_PATH=/path/to/my-local-harness/venv
